a=int(input("Enter a number: "))
nums = []
while True:
    if a==1:
        break
    elif a in nums:
        break
    else:
        nums.append(a)
        d=sum([int(i)*int(i) for i in str(a)])
        nums.append(d)
        a=d

if  a==1:
    print("Round number")
    print(nums)
else:
    print("Not a round number")
    print(nums)
